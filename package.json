{
  "name": "@_linked/cli",
  "version": "1.3.4",
  "description": "Command line tools for the @_linked/* packages and apps",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./preflight.css": "./preflight.css",
    "./*.css": "./lib/esm/*.css",
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "scripts": {
    "build": "rimraf ./lib && yarn build-esm && yarn build-cjs && yarn copy-to-lib && yarn dual-package",
    "build-cjs": "echo \"compiling CJS\" && rimraf ./lib/cjs && yarn tsc -p tsconfig-cjs.json",
    "build-esm": "echo \"compiling ESM\" && rimraf ./lib/esm && yarn tsc -p tsconfig-esm.json",
    "dual-package": "echo 'adding package.json to each lib folder for dual output support' && yarn tsconfig-to-dual-package ./tsconfig-cjs.json ./tsconfig-esm.json",
    "copy-to-lib": "echo '💫 Copying CSS assets to lib folder' && yarn copyfiles -u 1 'src/**/*.css' lib/esm && yarn copyfiles -u 1 'src/**/*.css' lib/cjs",
    "dev": "yarn tsc -p tsconfig-esm.json -w",
    "dev-cjs": "yarn tsc -p tsconfig-cjs.json -w",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx,css,scss}\" --check",
    "prettier:fix": "yarn prettier --write",
    "format": "yarn prettier:fix && yarn lint:fix"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "linked",
    "cli",
    "build",
    "tools"
  ],
  "repository": "https://github.com/linked-cm/cli",
  "author": {
    "name": "René Verheij",
    "url": "https://github.com/flyon",
    "email": "rpwverheij@gmail.com"
  },
  "license": "MPL-2.0",
  "linkedPackage": true,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lincd": "lib/esm/cli-deprecated.js",
    "lincd-cli": "lib/esm/cli-deprecated.js",
    "linked": "lib/esm/cli.js",
    "lnk": "lib/esm/cli.js"
  },
  "dependencies": {
    "@_linked/core": "^2.2.1",
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-decorators": "^7.24.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/register": "^7.23.7",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^20.12.7",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "babel-loader": "^9.1.3",
    "chalk": "^4.1.2",
    "child-process-promise": "^2.2.1",
    "colors": "^1.4.0",
    "commander": "^11.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "copyfiles": "^2.4.1",
    "create-esm-loader": "^0.2.5",
    "css-loader": "^6.10.0",
    "css-parse": "^2.0.0",
    "cssnano": "^7.0.7",
    "depcheck": "^1.4.7",
    "env-cmd": "^10.1.0",
    "find-nearest-package-json": "^2.0.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.12",
    "license-info-webpack-plugin": "^3.0.0",
    "mini-css-extract-plugin": "^2.8.1",
    "node-hook": "^1.0.0",
    "open": "^8.4.0",
    "ora": "^8.0.1",
    "postcss": "^8.5.3",
    "postcss-comment": "^2.0.0",
    "postcss-font-magician": "^4.0.0",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-modules": "^6.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.5",
    "postcss-reporter": "^7.1.0",
    "postcss-strip-inline-comments": "^0.1.5",
    "postcss-url": "^10.1.3",
    "react-refresh": "^0.18.0",
    "react-refresh-typescript": "^2.0.10",
    "require-extensions": "^0.0.4",
    "rimraf": "^5.0.7",
    "source-map-loader": "^5.0.0",
    "staged-git-files": "^1.3.0",
    "tailwindcss": "^4.1.4",
    "terminal-kit": "^3.1.1",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "tsconfig-to-dual-package": "^1.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.4.0",
    "typescript-plugin-css-modules": "^5.1.0",
    "webpack": "^5.90.3",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-license-plugin": "^4.4.2",
    "webpack-manifest-plugin": "^5.0.1",
    "webpack-typings-for-css": "^0.13.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "husky": "^9.0.11",
    "optimize-css-assets-webpack-plugin": "^6.0.1",
    "pinst": "^3.0.0",
    "prettier": "^3.2.5"
  },
  "peerDepencencies": {},
  "type": "module"
}
