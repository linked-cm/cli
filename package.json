{
  "name": "lincd-cli",
  "version": "0.2.75",
  "description": "Command line tools for the lincd.js library",
  "main": "lib/index.js",
  "scripts": {
    "prepublishOnly": "npm exec tsc",
    "build": "npm exec tsc",
    "postinstall": "husky install",
    "prepack": "npm exec tsc && pinst --disable && yarn version patch",
    "postpack": "pinst --enable",
    "dev": "npm exec tsc -w",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx,css,scss}\" --check",
    "prettier:fix": "yarn prettier --write",
    "format": "yarn prettier:fix && yarn lint:fix"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "lincd",
    "cli",
    "build",
    "tools"
  ],
  "repository": "https://github.com:Semantu/lincd.org",
  "author": {
    "name": "René Verheij",
    "url": "https://github.com/flyon",
    "email": "rpwverheij@gmail.com"
  },
  "license": "MPL-2.0",
  "bin": {
    "grunt": "expose-grunt.js",
    "lincd": "lib/cli.js",
    "lincd-cli": "lib/cli.js"
  },
  "dependencies": {
    "@babel/core": "^7.19.3",
    "@babel/plugin-proposal-decorators": "^7.19.3",
    "@babel/plugin-transform-runtime": "^7.19.1",
    "@babel/preset-env": "^7.19.3",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@lodder/grunt-postcss": "^3.1.1",
    "@types/node": "^18.11.10",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "babel-loader": "^8.2.5",
    "chalk": "4.1.0",
    "child-process-promise": "^2.2.1",
    "colors": "^1.4.0",
    "commander": "^11.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.1",
    "depcheck": "^1.4.3",
    "env-cmd": "^10.1.0",
    "find-nearest-package-json": "^2.0.1",
    "fs-extra": "^11.1.1",
    "glob": "^7.1.6",
    "grunt": "^1.6.1",
    "grunt-cli": "^1.4.3",
    "grunt-concurrent": "^3.0.0",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-exec": "^3.0.0",
    "grunt-ts": "^6.0.0-beta.22",
    "grunt-webpack": "^5.0.0",
    "license-info-webpack-plugin": "^3.0.0",
    "lincd": "^0.5",
    "lincd-jsonld": "^0.1.21",
    "lincd-modules": "^0.1",
    "load-grunt-tasks": "^5.1.0",
    "mini-css-extract-plugin": "^2.7.5",
    "open": "^8.4.0",
    "postcss": "^8.4.31",
    "postcss-comment": "^2.0.0",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "postcss-modules": "^6.0.0",
    "postcss-nested": "^6.0.1",
    "postcss-scss": "^4.0.9",
    "postcss-strip-inline-comments": "^0.1.5",
    "require-extensions": "^0.0.4",
    "sass": "^1.55.0",
    "sass-loader": "^13.0.2",
    "source-map-loader": "^4.0.0",
    "staged-git-files": "^1.3.0",
    "tailwindcss": "^3.2.7",
    "terser-webpack-plugin": "^5.3.6",
    "ts-loader": "^9.4.1",
    "tsconfig-paths-webpack-plugin": "^4.0.0",
    "typescript": "4.8.4",
    "webpack": "^5.76.3",
    "webpack-bundle-analyzer": "^4.6.1",
    "webpack-license-plugin": "^4.2.2"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "optimize-css-assets-webpack-plugin": "^6.0.1",
    "pinst": "^3.0.0",
    "prettier": "^3.0.3"
  },
  "peerDepencencies": {}
}
