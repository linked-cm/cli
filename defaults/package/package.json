{
  "name": "${package_name}",
  "description": "",
  "author": {
    "name": "",
    "email": "",
    "url": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "version": "1.0.0",
  "linkedPackage": true,
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/esm/index.d.ts",
  "license": "ISC",
  "scripts": {
    "start": "yarn linked dev",
    "build": "yarn linked build",
    "prepublishOnly": "yarn linked build production",
    "postpublish": "yarn linked register"
  },
  "keywords": [
    "linked",
    "linked data",
    "semantic web",
    "web3"
  ],
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "dependencies": {
    "@_linked/core": "^2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@_linked/cli": "^1.2",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "^5.7.3"
  }
}
