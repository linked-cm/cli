{
  "name": "${hyphen_name}",
  "displayName": "${name}",
  "description": "",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "linkedApp": true,
  "author": {
    "name": "",
    "url": "",
    "email": ""
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "scripts/start-server.js",
  "license": "MIT",
  "scripts": {
    "setup": "cp mrgit-template.json mrgit.json && yarn install && yarn mrgit sync && yarn install",
    "start": "node --import ./node_modules/@_linked/cli/lib/esm/loaders/register.js node_modules/.bin/linked start --env development",
    "build": "yarn linked build-app --env production",
    "prepare": "husky",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "server:prod": "yarn linked start --env production",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "yarn lint --fix",
    "prettier": "prettier \"src/**/*.{js,jsx,ts,tsx,css,scss}\" --check",
    "prettier:fix": "yarn prettier --write",
    "format": "yarn prettier:fix && yarn lint:fix"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write"
    ],
    "*.{scss,css,json}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "linked",
    "linked code",
    "linked data",
    "structured data",
    "RDF",
    "semantic web",
    "web3"
  ],
  "dependencies": {
    "@_linked/core": "^2.0",
    "@_linked/auth": "~1.0",
    "@_linked/server": "~1.0",
    "@_linked/server-utils": "~1.0",
    "react": "^18.2",
    "react-dom": "^18.2",
    "react-error-boundary": "^3.1.3",
    "react-router-dom": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "env-cmd": "^10.1.0",
    "eslint": "latest",
    "eslint-config-prettier": "^8.9.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "@_linked/cli": "^1.2",
    "mrgit": "latest",
    "nodemon": "^2.0.22",
    "pinst": "^3.0.0",
    "pm2": "^5.3.0",
    "typescript-plugin-css-modules": "^5.1.0",
    "which": "^3.0.1"
  },
  "packageManager": "yarn@3.6.1"
}
