{
  "extends" : "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "target": "es6",
    "outDir": "lib/esm",
    "moduleResolution": "node",
    "sourceMap": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "baseUrl": "./src",
    "types": ["node"]
  },
  "include": ["./src/**/*.ts"],
  "files": ["./src/index.ts", "./src/cli.ts"]
}
