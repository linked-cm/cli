{
  "compilerOptions": {
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es6",
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["./src/**/*.ts","./src/**/*.cts","./src/**/*.mts"],
  "files": ["./src/index.ts", "./src/cli.ts"]
}